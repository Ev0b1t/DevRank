PROJECT_NAME="SmartHire AI (DevRank)"
VERSION="0.2.0"

DB_URL="sqlite+aiosqlite:///./devrank.db"

LLM_PROVIDER="gemini"
GEMINI_API_KEY="your_gemini_key_here"
OPENAI_API_KEY="your_openai_key_here"
GITHUB_TOKEN="your_github_token_here"

MAX_CV_CHARS=8000
MAX_VACANCY_CHARS=2000
MAX_GITHUB_REPOS=6
MAX_REPO_DESC_CHARS=280
MAX_GITHUB_PAYLOAD_CHARS=12000
LOG_LEVEL="INFO"
LOG_DIR="logs"
LOG_FILE="devrank.log"
LOG_ROTATION="10 MB"
LOG_RETENTION="14 days"
